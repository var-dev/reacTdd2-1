{
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "test": "node --experimental-test-module-mocks --import tsx --test \"**/*.{test.ts,test.tsx}\"",
    "test-only": "node --test-only --import tsx --test ./**/*.test.ts --test ./**/*.test.tsx",
    "start": "node --import tsx ./src/index.ts",
    "server": "node --import tsx ./server/src/server.ts",
    "nodemon": "nodemon",
    "tsc": "tsc --noEmit --watch --preserveWatchOutput",
    "dev": "vite",
    "build": "relay-compiler && vite build",
    "preview": "vite preview",
    "relay": "relay-compiler",
    "relay:watch": "relay-compiler --watch"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.2.0",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "*",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^27.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "*",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-relay": "^18.2.1",
    "@types/relay-runtime": "^20.1.1",
    "@vitejs/plugin-react": "^5.1.2",
    "express": "^5.2.1",
    "graphql": "^16.13.2",
    "graphql-helix": "^1.13.0",
    "jsdom": "^27.4.0",
    "morgan": "^1.10.1",
    "nodemon": "^3.1.11",
    "quibble": "^0.9.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "relay-compiler": "^20.1.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-relay-lite": "^0.12.0"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "react-redux": "^9.2.0",
    "react-relay": "^20.1.1",
    "react-router": "^7.13.0",
    "redux-saga": "^1.4.2",
    "relay-runtime": "^20.1.1"
  }
}
